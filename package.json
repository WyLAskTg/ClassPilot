{
  "name": "classpilot",
  "version": "1.0.1",
  "description": "ClassPilot desktop course schedule planner.",
  "main": "main.js",
  "scripts": {
    "icons": "node scripts/create-icons.js",
    "start": "electron .",
    "build": "npm run icons && electron-builder --win --publish never",
    "screenshot": "electron scripts/capture-screenshot.js",
    "test": "node scripts/test-state.js && node --check app.js && node --check main.js && node --check preload.js && node --check scripts/create-icons.js && node --check scripts/after-pack.js && node --check scripts/capture-screenshot.js"
  },
  "keywords": [
    "course",
    "schedule",
    "desktop",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.1"
  },
  "build": {
    "appId": "com.local.classpilot",
    "productName": "ClassPilot",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "preload.js",
      "main.js",
      "package.json",
      "build/icon.png",
      "build/icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "ClassPilot",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
